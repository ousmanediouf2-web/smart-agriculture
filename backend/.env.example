# ── Base de données ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/smart-agriculture

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=votre_secret_jwt_tres_long_et_complexe
JWT_EXPIRES_IN=7d

# ── Telegram Bot (gratuit, illimité) ────────────────────────────────────────
# 1. Ouvrir Telegram → chercher @BotFather → envoyer /newbot → suivre les instructions
# 2. Copier le token donné par BotFather ci-dessous
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz
# Chat ID Telegram de l'administrateur (pour recevoir les alertes système)
# Pour l'obtenir : démarrer une conversation avec votre bot puis visiter
# https://api.telegram.org/bot<VOTRE_TOKEN>/getUpdates
ADMIN_TELEGRAM_CHAT_ID=123456789

# ── Webhook commandes Telegram (/on /off /status...) ────────────────────────
# Après le déploiement, activer le webhook UNE SEULE FOIS en visitant dans un navigateur :
# https://api.telegram.org/bot<VOTRE_TOKEN>/setWebhook?url=<URL_DE_VOTRE_BACKEND>/api/telegram/webhook
# Exemple : https://api.telegram.org/bot123456789:ABC.../setWebhook?url=https://smart-agriculture-5n9j.onrender.com/api/telegram/webhook
# Vérifier l'état du webhook : https://api.telegram.org/bot<VOTRE_TOKEN>/getWebhookInfo
ADMIN_PHONE_NUMBER=+221771234567       # Votre numéro WhatsApp admin

# ── Sécurité ──────────────────────────────────────────────────────────────────
INIT_SECRET=votre_secret_pour_initialiser_la_bd   # Protège /api/init-db
ESP32_API_KEY=cle_api_pour_esp32_si_necesaire

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://smart-agriculture-frontend.onrender.com

# ── Satellite (optionnel) ─────────────────────────────────────────────────────
# Sentinel Hub : créez un compte sur sentinel-hub.com (gratuit 30j puis payant)
SENTINEL_INSTANCE_ID=votre_instance_id_sentinel_hub
# Mapbox : token gratuit sur mapbox.com
MAPBOX_TOKEN=pk.votre_token_mapbox

# ── Environnement ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Météo ─────────────────────────────────────────────────────────────────────
# Clé gratuite sur https://openweathermap.org (60 requêtes/min)
OPENWEATHER_API_KEY=votre_cle_openweathermap

# ── Drone / WebODM ──────────────────────────────────────────────────────────
# Créer un compte sur https://webodm.net (gratuit limité)
# WEBODM_API_KEY=votre_token_webodm
