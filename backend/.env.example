# ── Base de données ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/smart-agriculture

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=votre_secret_jwt_tres_long_et_complexe
JWT_EXPIRES_IN=7d

# ── Twilio WhatsApp ───────────────────────────────────────────────────────────
# Créez un compte sur twilio.com, activez le sandbox WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=votre_auth_token_twilio
TWILIO_PHONE_NUMBER=+14155238886       # Numéro Twilio (SMS fallback)
TWILIO_WHATSAPP_NUMBER=+14155238886    # Numéro sandbox WhatsApp Twilio
ADMIN_PHONE_NUMBER=+221771234567       # Votre numéro WhatsApp admin

# ── Sécurité ──────────────────────────────────────────────────────────────────
INIT_SECRET=votre_secret_pour_initialiser_la_bd   # Protège /api/init-db
ESP32_API_KEY=cle_api_pour_esp32_si_necesaire

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://smart-agriculture-frontend.onrender.com

# ── Satellite (optionnel) ─────────────────────────────────────────────────────
# Sentinel Hub : créez un compte sur sentinel-hub.com (gratuit 30j puis payant)
SENTINEL_INSTANCE_ID=votre_instance_id_sentinel_hub
# Mapbox : token gratuit sur mapbox.com
MAPBOX_TOKEN=pk.votre_token_mapbox

# ── Environnement ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Météo ─────────────────────────────────────────────────────────────────────
# Clé gratuite sur https://openweathermap.org (60 requêtes/min)
OPENWEATHER_API_KEY=votre_cle_openweathermap

# ── Drone / WebODM ──────────────────────────────────────────────────────────
# Créer un compte sur https://webodm.net (gratuit limité)
# WEBODM_API_KEY=votre_token_webodm
